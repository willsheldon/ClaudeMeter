--- Pinemeter/Models/AppSettings.swift ---
35: 
36:     /// Whether menu bar icons are shown in color instead of monochrome.
37:     var isColoredIcon: Bool
38: 
39:     static let `default` = AppSettings(
40:         refreshInterval: 60,
41:         hasNotificationsEnabled: true,
42:         notificationThresholds: .default,
43:         isFirstLaunch: true,
44:         cachedOrganizationId: nil,
45:         isSonnetUsageShown: false,
46:         isChatGPTUsageShown: false,
47:         iconStyle: .dualBar,
48:         isColoredIcon: true
49:     )
50: 
51:     enum CodingKeys: String, CodingKey {
52:         case refreshInterval = "refresh_interval"
53:         case hasNotificationsEnabled = "notifications_enabled"
54:         case notificationThresholds = "notification_thresholds"
55:         case isFirstLaunch = "is_first_launch"
56:         case cachedOrganizationId = "cached_organization_id"
57:         case isSonnetUsageShown = "show_sonnet_usage"
58:         case isChatGPTUsageShown = "show_chatgpt_usage"
59:         case legacyOpenAIUsageShown = "show_openai_usage"
60:         case iconStyle = "icon_style"
61:         case isColoredIcon = "is_colored_icon"
62:     }
63: }
64: 
65: extension AppSettings {
66:     init(from decoder: Decoder) throws {
67:         let container = try decoder.container(keyedBy: CodingKeys.self)
68:         let defaults = AppSettings.default
69: 
70:         refreshInterval = try container.decodeIfPresent(TimeInterval.self, forKey: .refreshInterval) ?? defaults.refreshInterval
71:         hasNotificationsEnabled = try container.decodeIfPresent(Bool.self, forKey: .hasNotificationsEnabled) ?? defaults.hasNotificationsEnabled
72:         notificationThresholds = try container.decodeIfPresent(NotificationThresholds.self, forKey: .notificationThresholds) ?? defaults.notificationThresholds
73:         isFirstLaunch = try container.decodeIfPresent(Bool.self, forKey: .isFirstLaunch) ?? defaults.isFirstLaunch
74:         cachedOrganizationId = try container.decodeIfPresent(UUID.self, forKey: .cachedOrganizationId)
75:         isSonnetUsageShown = try container.decodeIfPresent(Bool.self, forKey: .isSonnetUsageShown) ?? defaults.isSonnetUsageShown
76:         isChatGPTUsageShown = try container.decodeIfPresent(Bool.self, forKey: .isChatGPTUsageShown)
77:             ?? container.decodeIfPresent(Bool.self, forKey: .legacyOpenAIUsageShown)
78:             ?? defaults.isChatGPTUsageShown
79:         iconStyle = try container.decodeIfPresent(IconStyle.self, forKey: .iconStyle) ?? defaults.iconStyle
80:         isColoredIcon = try container.decodeIfPresent(Bool.self, forKey: .isColoredIcon) ?? defaults.isColoredIcon
81:     }
82: 
83:     init(
84:         refreshInterval: TimeInterval,
85:         hasNotificationsEnabled: Bool,
86:         notificationThresholds: NotificationThresholds,
87:         isFirstLaunch: Bool,
88:         cachedOrganizationId: UUID?,
89:         isSonnetUsageShown: Bool,
90:         isChatGPTUsageShown: Bool,
91:         iconStyle: IconStyle
92:     ) {
93:         self.refreshInterval = refreshInterval
94:         self.hasNotificationsEnabled = hasNotificationsEnabled
95:         self.notificationThresholds = notificationThresholds
96:         self.isFirstLaunch = isFirstLaunch
97:         self.cachedOrganizationId = cachedOrganizationId
98:         self.isSonnetUsageShown = isSonnetUsageShown
99:         self.isChatGPTUsageShown = isChatGPTUsageShown
100:         self.iconStyle = iconStyle
101:         self.isColoredIcon = AppSettings.default.isColoredIcon
102:     }
103: 
104:     func encode(to encoder: Encoder) throws {
105:         var container = encoder.container(keyedBy: CodingKeys.self)
106:         try container.encode(refreshInterval, forKey: .refreshInterval)
107:         try container.encode(hasNotificationsEnabled, forKey: .hasNotificationsEnabled)
108:         try container.encode(notificationThresholds, forKey: .notificationThresholds)
109:         try container.encode(isFirstLaunch, forKey: .isFirstLaunch)
110:         try container.encodeIfPresent(cachedOrganizationId, forKey: .cachedOrganizationId)
111:         try container.encode(isSonnetUsageShown, forKey: .isSonnetUsageShown)
112:         try container.encode(isChatGPTUsageShown, forKey: .isChatGPTUsageShown)
113:         try container.encode(iconStyle, forKey: .iconStyle)
114:         try container.encode(isColoredIcon, forKey: .isColoredIcon)
115:     }
--- PinemeterTests/SettingsRepositoryTests.swift ---
1: //
2: //  SettingsRepositoryTests.swift
3: //  PinemeterTests
4: //
5: //  Created by Edd on 2026-01-09.
6: //
7: 
8: import XCTest
9: @testable import Pinemeter
10: 
11: final class SettingsRepositoryTests: XCTestCase {
12:     func test_settingsPersistAcrossLaunches() async throws {
13:         let suiteName = "SettingsRepositoryTests.\(UUID().uuidString)"
14:         let userDefaults = UserDefaults(suiteName: suiteName)
15:         defer { userDefaults?.removePersistentDomain(forName: suiteName) }
16: 
17:         let repository = SettingsRepository(userDefaults: userDefaults ?? .standard)
18:         var settings = AppSettings.default
19:         settings.refreshInterval = 300
20:         settings.hasNotificationsEnabled = false
21:         settings.isFirstLaunch = false
22:         settings.cachedOrganizationId = UUID(uuidString: TestConstants.organizationUUIDString)
23:         settings.iconStyle = .dualBar
24:         settings.isColoredIcon = false
25:         settings.isChatGPTUsageShown = true
26: 
27:         try await repository.save(settings)
28:         let loaded = await repository.load()
29: 
30:         XCTAssertEqual(loaded, settings)
31:     }
32: 
33:     func test_settingsDecodingWithoutIsColoredIcon_usesDefault() throws {
34:         let data = """
35:         {
36:           "refresh_interval": 300,
37:           "notifications_enabled": false,
38:           "notification_thresholds": {
39:             "warning_threshold": 70,
40:             "critical_threshold": 90,
41:             "notify_on_reset": false
42:           },
43:           "is_first_launch": false,
44:           "cached_organization_id": null,
45:           "show_sonnet_usage": true,
46:           "icon_style": "dual_bar"
47:         }
48:         """.data(using: .utf8)!
49: 
50:         let settings = try JSONDecoder().decode(AppSettings.self, from: data)
51: 
52:         XCTAssertTrue(settings.isColoredIcon)
53:     }
54: 
55:     func test_defaultSettings_hideChatGPTUsage() {
56:         XCTAssertFalse(AppSettings.default.isChatGPTUsageShown)
57:     }
58: 
59:     func test_notificationStatePersistsAcrossLaunches() async throws {
60:         let suiteName = "SettingsRepositoryTests.\(UUID().uuidString)"
61:         let userDefaults = UserDefaults(suiteName: suiteName)
62:         defer { userDefaults?.removePersistentDomain(forName: suiteName) }
63: 
64:         let repository = SettingsRepository(userDefaults: userDefaults ?? .standard)
65:         var state = NotificationState()
66:         state.hasWarningBeenNotified = true
67:         state.hasCriticalBeenNotified = true
68:         state.lastPercentage = 85
69: 
70:         try await repository.saveNotificationState(state)
71:         let loaded = await repository.loadNotificationState()
72: 
73:         XCTAssertEqual(loaded, state)
74:     }
75: }
