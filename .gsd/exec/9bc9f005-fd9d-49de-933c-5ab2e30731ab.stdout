6: import XCTest
7: @testable import Pinemeter
8: 
9: final class CacheRepositoryTests: XCTestCase {
10:     private var temporaryRoot: URL!
11:     private var appSupportBaseURL: URL!
12:     private var homeBaseURL: URL!
13: 
14:     override func setUpWithError() throws {
15:         try super.setUpWithError()
16: 
17:         temporaryRoot = FileManager.default.temporaryDirectory
18:             .appendingPathComponent("PinemeterTests", isDirectory: true)
19:             .appendingPathComponent(UUID().uuidString, isDirectory: true)
20:         appSupportBaseURL = temporaryRoot.appendingPathComponent("Application Support", isDirectory: true)
21:         homeBaseURL = temporaryRoot.appendingPathComponent("Home", isDirectory: true)
22: 
23:         try FileManager.default.createDirectory(at: appSupportBaseURL, withIntermediateDirectories: true)
24:         try FileManager.default.createDirectory(at: homeBaseURL, withIntermediateDirectories: true)
25:     }
26: 
27:     override func tearDownWithError() throws {
28:         if let temporaryRoot {
29:             try? FileManager.default.removeItem(at: temporaryRoot)
30:         }
31: 
32:         temporaryRoot = nil
33:         appSupportBaseURL = nil
34:         homeBaseURL = nil
35: 
88:         XCTAssertFalse(FileManager.default.fileExists(atPath: newPrivateCacheURL.path))
89:         XCTAssertFalse(FileManager.default.fileExists(atPath: legacyPrivateCacheURL.path))
90:         XCTAssertFalse(FileManager.default.fileExists(atPath: newPublicExportURL.path))
91:         XCTAssertFalse(FileManager.default.fileExists(atPath: legacyPublicExportURL.path))
92:         XCTAssertNil(await repository.get())
93:         XCTAssertNil(await repository.getLastKnown())
94:     }
95: 
96:     private func makeRepository() -> CacheRepository {
97:         CacheRepository(
98:             fileManager: .default,
99:             appSupportBaseURL: appSupportBaseURL,
100:             homeBaseURL: homeBaseURL
101:         )
102:     }
103: 
104:     private var newPrivateCacheURL: URL {
105:         appSupportBaseURL
106:             .appendingPathComponent("com.pinemeter", isDirectory: true)
107:             .appendingPathComponent("usage_cache.json")
108:     }
109: 
110:     private var legacyPrivateCacheURL: URL {
111:         appSupportBaseURL
112:             .appendingPathComponent("com.claudemeter", isDirectory: true)
