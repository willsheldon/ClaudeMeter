## workflows
.github/workflows/deploy-pages.yml:
  1: name: Deploy to GitHub Pages
  22: runs-on: ubuntu-latest
  25: name: github-pages
  29: - name: Checkout
  32: - name: Fetch latest release version
  37: RELEASE_TAG=$(gh release view --json tagName --jq '.tagName' 2>/dev/null || echo "")
  38: if [ -n "$RELEASE_TAG" ]; then
  39: VERSION="${RELEASE_TAG#v}"
  40: echo "Found release version: $VERSION"
  43: echo "No releases found, keeping default version"
  47: - name: Inject version into site
  55: - name: Setup Pages
  58: - name: Upload artifact
  59: uses: actions/upload-pages-artifact@v5
  63: - name: Deploy to GitHub Pages
.github/workflows/release.yml:
  1: name: Release Pinemeter
  7: build-and-release:
  8: runs-on: macos-latest
  13: EXPECTED_SIGNING_IDENTITY: "Developer ID Application: AUTIMO SYSTEMS INC (HMR9RDR6M2)"
  14: EXPECTED_TEAM_ID: HMR9RDR6M2
  17: - name: Checkout code
  20: - name: Extract version from changelog
  26: - name: Extract changelog
  45: - name: Set up Xcode
  48: xcode-version: latest-stable
  50: - name: Update version in project
  53: sed -i '' "s/MARKETING_VERSION = [^;]*/MARKETING_VERSION = ${{ steps.version.outputs.version }}/g" Pinemeter.xcodeproj/project.pbxproj
  57: sed -i '' "s/CURRENT_PROJECT_VERSION = [^;]*/CURRENT_PROJECT_VERSION = $BUILD_NUMBER/g" Pinemeter.xcodeproj/project.pbxproj
  61: - name: Install Apple certificate
  63: APPLE_CERTIFICATE_BASE64: ${{ secrets.APPLE_CERTIFICATE_BASE64 }}
  64: APPLE_CERTIFICATE_PASSWORD: ${{ secrets.APPLE_CERTIFICATE_PASSWORD }}
  66: KEYCHAIN_PATH=$RUNNER_TEMP/app-signing.keychain-db
  69: echo "$APPLE_CERTIFICATE_BASE64" | base64 --decode > $RUNNER_TEMP/certificate.p12
  76: -P "$APPLE_CERTIFICATE_PASSWORD" \
  80: security set-key-partition-list -S apple-tool:,apple: -s -k "$KEYCHAIN_PASSWORD" $KEYCHAIN_PATH
  83: if ! security find-certificate -c "$EXPECTED_SIGNING_IDENTITY" $KEYCHAIN_PATH >/dev/null; then
  84: echo "::error::Expected signing certificate not found: $EXPECTED_SIGNING_IDENTITY"
  85: security find-identity -v -p codesigning $KEYCHAIN_PATH || true
  93: - name: Build app
  95: xcodebuild clean build \
  96: -project Pinemeter.xcodeproj \
  97: -scheme Pinemeter \
  98: -configuration Release \
  101: CODE_SIGN_STYLE=Manual \
  102: CODE_SIGN_IDENTITY="$EXPECTED_SIGNING_IDENTITY" \
  104: CODE_SIGN_INJECT_BASE_ENTITLEMENTS=NO \
  105: OTHER_CODE_SIGN_FLAGS="--timestamp --options runtime"
  107: - name: Verify code signature
  109: APP_PATH="build/Build/Products/Release/Pinemeter.app"
  110: echo "Verifying code signature..."
  111: codesign -vvv --deep --strict "$APP_PATH"
  112: echo "Checking signature details..."
  113: SIGNATURE_DETAILS=$(codesign -dvv "$APP_PATH" 2>&1)
  114: echo "$SIGNATURE_DETAILS"
  115: if ! echo "$SIGNATURE_DETAILS" | grep -Fq "Authority=$EXPECTED_SIGNING_IDENTITY"; then
  116: echo "::error::App was not signed by expected identity: $EXPECTED_SIGNING_IDENTITY"
  119: if ! echo "$SIGNATURE_DETAILS" | grep -Fq "TeamIdentifier=$EXPECTED_TEAM_ID"; then
  120: echo "::error::App was not signed with expected team: $EXPECTED_TEAM_ID"
  124: codesign -d --entitlements - "$APP_PATH"
  126: - name: Notarize app
  128: APP_STORE_CONNECT_API_KEY_BASE64: ${{ secrets.APP_STORE_CONNECT_API_KEY_BASE64 }}
  129: APP_STORE_CONNECT_KEY_ID: ${{ secrets.APP_STORE_CONNECT_KEY_ID }}
  130: APP_STORE_CONNECT_ISSUER_ID: ${{ secrets.APP_STORE_CONNECT_ISSUER_ID }}
  132: APP_PATH="build/Build/Products/Release/Pinemeter.app"
  136: /usr/bin/ditto -c -k --keepParent "$APP_PATH" "$RUNNER_TEMP/Pinemeter-notarize.zip"
  138: echo "Submitting for notarization..."
  139: SUBMIT_OUTPUT=$(xcrun notarytool submit "$RUNNER_TEMP/Pinemeter-notarize.zip" \
  150: # Check if notarization succeeded
  152: echo "Notarization succeeded!"
  154: echo "Notarization failed. Fetching detailed log..."
  155: xcrun notarytool log "$SUBMISSION_ID" \
  159: rm -f $RUNNER_TEMP/AuthKey.p8 $RUNNER_TEMP/Pinemeter-notarize.zip
  163: echo "Stapling notarization ticket..."
  170: rm -f $RUNNER_TEMP/AuthKey.p8 $RUNNER_TEMP/Pinemeter-notarize.zip
  172: - name: Create ZIP
  174: cd build/Build/Products/Release
  175: xattr -cr Pinemeter.app
  176: find Pinemeter.app -name '._*' -delete
  177: zip -r ../../../../Pinemeter-${{ steps.version.outputs.version }}.zip Pinemeter.app
  179: - name: Create GitHub Release
  180: uses: softprops/action-gh-release@v3
  182: tag_name: v${{ steps.version.outputs.version }}
  183: name: Pinemeter v${{ steps.version.outputs.version }}
  185: files: Pinemeter-${{ steps.version.outputs.version }}.zip
  187: prerelease: false
  189: GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
  191: - name: Update Homebrew tap
  193: TAP_TOKEN: ${{ secrets.HOMEBREW_TAP_TOKEN }}
  195: SHA=$(shasum -a 256 Pinemeter-${{ steps.version.outputs.version }}.zip | cut -d' ' -f1)
  197: git clone https://x-access-token:${TAP_TOKEN}@github.com/eddmann/homebrew-tap.git
  198: cd homebrew-tap
  200: sed -i '' "s/version \".*\"/version \"${{ steps.version.outputs.version }}\"/" Casks/pinemeter.rb
  201: sed -i '' "s/sha256 \".*\"/sha256 \"${SHA}\"/" Casks/pinemeter.rb
  205: git add Casks/pinemeter.rb
  206: git commit -m "chore(pinemeter): update to ${{ steps.version.outputs.version }}"
  209: - name: Cleanup keychain
.github/workflows/test.yml:
  1: name: Test
  12: group: test-${{ github.ref }}
  16: test:
  17: runs-on: macos-latest
  20: - name: Checkout
  23: - name: Set up Xcode
  26: xcode-version: latest-stable
  28: - name: Run tests
  30: xcodebuild test \
  31: -project Pinemeter.xcodeproj \
  32: -scheme Pinemeter \
  34: -skip-testing:PinemeterTests/MenuBarIconSnapshotTests \
  35: CODE_SIGN_IDENTITY="-" \
  36: CODE_SIGNING_REQUIRED=NO \
  37: CODE_SIGNING_ALLOWED=NO
