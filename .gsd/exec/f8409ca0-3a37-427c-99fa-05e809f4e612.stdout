21:     init(fileManager: FileManager = .default) {
22:         let appSupport = fileManager.urls(
23:             for: .applicationSupportDir,
24:             in: .userDomainMask
25:         ).first!
26:         self.init(
27:             fileManager: fileManager,
28:             appSupportBaseURL: appSupport,
29:             homeBaseURL: fileManager.homeDirForCurrentUser
30:         )
31:     }
32: 
33:     init(
34:         fileManager: FileManager = .default,
35:         appSupportBaseURL: URL,
36:         homeBaseURL: URL
37:     ) {
38:         self.fileManager = fileManager
39: 
40:         let cacheDir = appSupportBaseURL.appendingPathComponent("com.pinemeter", isDir: true)
41:         let legacyCacheDir = appSupportBaseURL.appendingPathComponent("com.claudemeter", isDir: true)
42:         try? fileManager.createDir(at: cacheDir, withIntermediateDirectories: true)
43: 
44:         self.diskCacheURL = cacheDir.appendingPathComponent("usage_cache.json")
45:         self.legacyDiskCacheURL = legacyCacheDir.appendingPathComponent("usage_cache.json")
46: 
47:         // Public JSON export at ~/.pinemeter/usage.json for external tools.
48:         // Continue writing the legacy ~/.claudemeter/usage.json export for milestone compatibility.
49:         let publicDir = homeBaseURL.appendingPathComponent(".pinemeter", isDir: true)
50:         let legacyPublicDir = homeBaseURL.appendingPathComponent(".claudemeter", isDir: true)
51:         try? fileManager.createDir(at: publicDir, withIntermediateDirectories: true)
52:         try? fileManager.createDir(at: legacyPublicDir, withIntermediateDirectories: true)
53:         self.publicJSONURL = publicDir.appendingPathComponent("usage.json")
54:         self.legacyPublicJSONURL = legacyPublicDir.appendingPathComponent("usage.json")
55:     }
