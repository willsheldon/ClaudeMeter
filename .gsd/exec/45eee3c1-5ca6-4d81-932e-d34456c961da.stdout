.github/workflows/release.yml:114:          APP_PATH="build/Build/Products/Release/ClaudeMeter.app"
.github/workflows/release.yml:118:          /usr/bin/ditto -c -k --keepParent "$APP_PATH" "$RUNNER_TEMP/ClaudeMeter-notarize.zip"
.github/workflows/release.yml:121:          SUBMIT_OUTPUT=$(xcrun notarytool submit "$RUNNER_TEMP/ClaudeMeter-notarize.zip" \
.github/workflows/release.yml:141:            rm -f $RUNNER_TEMP/AuthKey.p8 $RUNNER_TEMP/ClaudeMeter-notarize.zip
.github/workflows/release.yml:152:          rm -f $RUNNER_TEMP/AuthKey.p8 $RUNNER_TEMP/ClaudeMeter-notarize.zip
.github/workflows/release.yml:157:          xattr -cr ClaudeMeter.app
.github/workflows/release.yml:158:          find ClaudeMeter.app -name '._*' -delete
.github/workflows/release.yml:159:          zip -r ../../../../ClaudeMeter-${{ steps.version.outputs.version }}.zip ClaudeMeter.app
.github/workflows/release.yml:165:          name: ClaudeMeter v${{ steps.version.outputs.version }}
.github/workflows/release.yml:167:          files: ClaudeMeter-${{ steps.version.outputs.version }}.zip
.github/workflows/release.yml:177:          SHA=$(shasum -a 256 ClaudeMeter-${{ steps.version.outputs.version }}.zip | cut -d' ' -f1)
.github/workflows/release.yml:182:          sed -i '' "s/version \".*\"/version \"${{ steps.version.outputs.version }}\"/" Casks/claudemeter.rb
.github/workflows/release.yml:183:          sed -i '' "s/sha256 \".*\"/sha256 \"${SHA}\"/" Casks/claudemeter.rb
.github/workflows/release.yml:187:          git add Casks/claudemeter.rb
.github/workflows/release.yml:188:          git commit -m "chore(claudemeter): update to ${{ steps.version.outputs.version }}"

