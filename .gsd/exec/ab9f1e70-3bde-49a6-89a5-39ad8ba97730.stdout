8: import Foundation
9: 
10: /// Application-wide constants
11: enum Constants {
12:     /// Cache configuration
13:     enum Cache {
14:         /// Memory cache time-to-live (slightly less than minimum refresh interval)
15:         static let ttl: TimeInterval = 55
16: 
17:         /// Maximum number of cached icons
18:         static let maxIconCacheSize = 100
19:     }
20: 
21:     /// Network configuration
22:     enum Network {
23:         /// Maximum number of retry attempts for failed requests
24:         static let maxRetries = 3
25: 
26:         /// Base delay multiplier for exponential backoff (network errors)
27:         static let backoffBase: Double = 2.0
28: 
29:         /// Base delay multiplier for rate limit backoff (more aggressive)
30:         static let rateLimitBackoffBase: Double = 3.0
31:     }
32: 
33:     /// Refresh intervals (in seconds)
34:     enum Refresh {
35:         /// Minimum refresh interval
36:         static let minimum: TimeInterval = 60
37: 
38:         /// Maximum refresh interval
39:         static let maximum: TimeInterval = 600
40: 
41:         /// Staleness threshold (2x max refresh interval to account for retries/delays)
42:         static let stalenessThreshold: TimeInterval = 1200
43:     }
44: 
45:     /// Pacing/risk calculation configuration
46:     enum Pacing {
47:         /// 5-hour session window duration
48:         static let sessionWindow: TimeInterval = 5 * 60 * 60
49: 
50:         /// 7-day weekly window duration
51:         static let weeklyWindow: TimeInterval = 7 * 24 * 60 * 60
52: 
53:         /// Ratio threshold for "at risk" status (using faster than sustainable)
54:         static let riskThreshold: Double = 1.2
55:     }
56: 
57:     /// Usage threshold configuration
58:     enum Thresholds {
59:         /// Visual status boundaries (fixed, for icon colors)
60:         /// These determine when the icon color changes from green → orange → red
61:         enum Status {
62:             /// Percentage where warning status begins (orange) - safe is 0..<warningStart
63:             static let warningStart: Double = 50
64:             /// Percentage where critical status begins (red) - warning is warningStart..<criticalStart
65:             static let criticalStart: Double = 80
66:         }
67: 
68:         /// Notification threshold configuration (user-configurable)
69:         enum Notification {
70:             /// Default warning notification threshold
71:             static let warningDefault: Double = 75
72:             /// Default critical notification threshold
73:             static let criticalDefault: Double = 90
74: 
75:             /// Slider bounds for warning threshold setting
76:             static let warningMin: Double = 50
77:             static let warningMax: Double = 90
78: 
79:             /// Slider bounds for critical threshold setting
80:             static let criticalMin: Double = 75
81:             static let criticalMax: Double = 100
82: 
83:             /// Slider step increment
84:             static let step: Double = 5
85:         }
86:     }
87: }

Constant paths counts:
Constants.Cache.ttl 1
Constants.Cache.maxIconCacheSize 1
Constants.Network.maxRetries 1
Constants.Network.backoffBase 2
Constants.Network.rateLimitBackoffBase 1
Constants.Network.timeout 0
Constants.MenuBar.iconSize 0
Constants.MenuBar.updateInterval 0
Constants.Defaults.refreshInterval 0
Constants.UserDefaults 0
