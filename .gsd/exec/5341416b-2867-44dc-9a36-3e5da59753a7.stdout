70:         let encoder = JSONEncoder()
71:         encoder.dateEncodingStrategy = .iso8601
72: 
73:         guard let jsonData = try? encoder.encode(data) else {
74:             return
75:         }
76: 
77:         do {
78:             try jsonData.write(to: diskCacheURL, options: .atomic)
79:         } catch {
80:             // Silently fail
81:         }
82: 
83:         // Also write to public location for external tools (statusline scripts, etc.)
84:         // Note: Ideally this would be a separate service, but since we always export
85:         // when caching fresh data, co-locating here avoids additional coordination.
86:         saveToPublicJSON(data)
87:     }
88: 
89:     private func saveToPublicJSON(_ data: UsageData) {
90:         let encoder = JSONEncoder()
91:         encoder.dateEncodingStrategy = .iso8601
92:         encoder.outputFormatting = [.prettyPrinted, .sortedKeys]
93: 
94:         guard let jsonData = try? encoder.encode(data) else {
95:             return
96:         }
97: 
98:         do {
99:             try jsonData.write(to: publicJSONURL, options: .atomic)
100:         } catch {
101:             // Silently fail - external tools location is optional
102:         }
103:     }
104: 
105:     private func loadFromDisk() async -> UsageData? {
106:         guard let jsonData = try? Data(contentsOf: diskCacheURL) else {
107:             return nil
108:         }
109: 
110:         let decoder = JSONDecoder()
111:         decoder.dateDecodingStrategy = .iso8601
112: 
113:         do {
114:             return try decoder.decode(UsageData.self, from: jsonData)
115:         } catch {
116:             return nil
117:         }
118:     }
119: }
