8: import Foundation
9: 
10: /// Actor-isolated two-tier cache repository
11: actor CacheRepository: CacheRepositoryProtocol {
12:     private var memoryCache: UsageData?
13:     private var memoryCacheTimestamp: Date?
14:     private let cacheTTL: TimeInterval = Constants.Cache.ttl
15:     private let diskCacheURL: URL
16:     private let publicJSONURL: URL
17: 
18:     init(fileManager: FileManager = .default) {
19:         let appSupport = fileManager.urls(
20:             for: .applicationSupportDirectory,
21:             in: .userDomainMask
22:         ).first!
23: 
24:         let cacheDir = appSupport.appendingPathComponent("com.claudemeter", isDirectory: true)
25:         try? fileManager.createDirectory(at: cacheDir, withIntermediateDirectories: true)
26: 
27:         self.diskCacheURL = cacheDir.appendingPathComponent("usage_cache.json")
28: 
29:         // Public JSON export at ~/.claudemeter/usage.json for external tools
30:         let homeDir = fileManager.homeDirectoryForCurrentUser
31:         let publicDir = homeDir.appendingPathComponent(".claudemeter", isDirectory: true)
32:         try? fileManager.createDirectory(at: publicDir, withIntermediateDirectories: true)
33:         self.publicJSONURL = publicDir.appendingPathComponent("usage.json")
34:     }
35: 
36:     /// Get cached usage data (respects TTL)
37:     func get() async -> UsageData? {
38:         // Check in-memory cache first
39:         if let cached = memoryCache,
40:            let timestamp = memoryCacheTimestamp,
41:            Date().timeIntervalSince(timestamp) < cacheTTL {
42:             return cached
43:         }
44: 
45:         // Memory cache is stale or missing
46:         return nil
47:     }
48: 
49:     /// Cache usage data in both memory and disk
50:     func set(_ data: UsageData) async {
51:         memoryCache = data
52:         memoryCacheTimestamp = Date()
53:         await saveToDisk(data)
54:     }
55: 
56:     /// Invalidate memory cache
57:     func invalidate() async {
58:         memoryCache = nil
59:         memoryCacheTimestamp = nil
60:     }
61: 
62:     /// Get last known data from disk (ignores TTL) for offline display
63:     func getLastKnown() async -> UsageData? {
64:         await loadFromDisk()
65:     }
66: 
67:     // MARK: - Private Methods
68: 
69:     private func saveToDisk(_ data: UsageData) async {
70:         let encoder = JSONEncoder()
71:         encoder.dateEncodingStrategy = .iso8601
72: 
73:         guard let jsonData = try? encoder.encode(data) else {
74:             return
75:         }
76: 
77:         do {
78:             try jsonData.write(to: diskCacheURL, options: .atomic)
79:         } catch {
