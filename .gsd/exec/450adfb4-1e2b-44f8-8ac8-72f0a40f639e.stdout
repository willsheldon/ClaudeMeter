1057:     func test_chatGPTCredentialLifecycle_recoversFromInvalidClearAndReacquire() async throws {
1058:         let expectedUsage = ChatGPTUsageData(
1059:             rows: [.init(label: "Codex Tasks", usedPercent: 24, resetAt: nil)],
1060:             lastUpdated: Date(timeIntervalSince1970: 0)
1061:         )
1062:         let settingsRepository = SettingsRepositoryFake()
1063:         let keychainRepository = KeychainRepositoryFake()
1064:         let notificationService = NotificationServiceSpy()
1065:         let chatGPTSessionRepository = AppModelChatGPTSessionRepositoryFake()
1066:         let invalidChatGPTUsageService = AppModelChatGPTUsageServiceStub(
1067:             fetchUsageResult: .success(expectedUsage),
1068:             validateResult: false
1069:         )
1070:         let invalidModel = AppModel(
1071:             settingsRepository: settingsRepository,
1072:             keychainRepository: keychainRepository,
1073:             usageService: UsageServiceStub(fetchUsageResult: .failure(TestError(message: TestConstants.unexpectedErrorMessage))),
1074:             chatGPTUsageService: invalidChatGPTUsageService,
1075:             chatGPTSessionRepository: chatGPTSessionRepository,
1076:             notificationService: notificationService
1077:         )
1078: 
1079:         let rejected = try await invalidModel.validateAndSaveChatGPTSessionCookie("synthetic-chatgpt-session-cookie")
1080: 
1081:         XCTAssertFalse(rejected)
1082:         XCTAssertFalse(invalidModel.hasChatGPTSessionCookie)
1083:         XCTAssertEqual(invalidModel.chatGPTCredentialState.health, .invalid)
1084:         XCTAssertEqual(invalidModel.chatGPTCredentialState.failureCategory, .providerRejected)
1085:         do {
1086:             _ = try await chatGPTSessionRepository.load(account: ChatGPTUsageService.defaultSessionAccount)
1087:             XCTFail("Expected missing ChatGPT session after invalid validation")
1088:         } catch ChatGPTSessionRepositoryError.notFound {
1089:             // Expected
1090:         } catch {
1091:             XCTFail("Unexpected error: \(error)")
1092:         }
1093: 
1094:         let validChatGPTUsageService = AppModelChatGPTUsageServiceStub(
1095:             fetchUsageResult: .success(expectedUsage),
1096:             validateResult: true
1097:         )
1098:         let setupModel = AppModel(
1099:             settingsRepository: settingsRepository,
1100:             keychainRepository: keychainRepository,
1101:             usageService: UsageServiceStub(fetchUsageResult: .failure(TestError(message: TestConstants.unexpectedErrorMessage))),
1102:             chatGPTUsageService: validChatGPTUsageService,
1103:             chatGPTSessionRepository: chatGPTSessionRepository,
1104:             notificationService: notificationService
1105:         )
1106: 
1107:         let acquired = try await setupModel.validateAndSaveChatGPTSessionCookie("synthetic-chatgpt-session-cookie")
1108: 
1109:         XCTAssertTrue(acquired)
1110:         XCTAssertTrue(setupModel.hasChatGPTSessionCookie)
1111:         XCTAssertTrue(setupModel.settings.isChatGPTUsageShown)
1112:         let savedChatGPTSession = try await chatGPTSessionRepository.load(account: ChatGPTUsageService.defaultSessionAccount)
1113: 
1114:         XCTAssertEqual(setupModel.chatGPTCredentialState.health, .valid)
1115:         XCTAssertEqual(setupModel.chatGPTUsageData, expectedUsage)
1116:         XCTAssertEqual(savedChatGPTSession.sessionCookie, "synthetic-chatgpt-session-cookie")
1117: 
1118:         var reuseSettings = AppSettings.default
1119:         reuseSettings.isChatGPTUsageShown = true
1120:         try await settingsRepository.save(reuseSettings)
1121:         let reuseModel = AppModel(
1122:             settingsRepository: settingsRepository,
1123:             keychainRepository: keychainRepository,
1124:             usageService: UsageServiceStub(fetchUsageResult: .failure(TestError(message: TestConstants.unexpectedErrorMessage))),
1125:             chatGPTUsageService: validChatGPTUsageService,
1126:             chatGPTSessionRepository: chatGPTSessionRepository,
1127:             notificationService: notificationService
1128:         )
1129: 
1130:         await reuseModel.bootstrap()
1131: 
1132:         XCTAssertTrue(reuseModel.hasChatGPTSessionCookie)
1133:         XCTAssertEqual(reuseModel.chatGPTCredentialState.health, .valid)
1134:         XCTAssertEqual(reuseModel.chatGPTUsageData, expectedUsage)
1135: 
1136:         try await setupModel.clearChatGPTSessionCookie()
1137: 
1138:         XCTAssertFalse(setupModel.hasChatGPTSessionCookie)
1139:         XCTAssertFalse(setupModel.settings.isChatGPTUsageShown)
1140:         XCTAssertNil(setupModel.chatGPTUsageData)
1141:         XCTAssertNil(setupModel.chatGPTErrorMessage)
1142:         XCTAssertEqual(setupModel.chatGPTCredentialState.health, .missing)
1143:         XCTAssertEqual(setupModel.chatGPTCredentialState.failureCategory, .missing)
1144: 
1145:         let reacquired = try await setupModel.validateAndSaveChatGPTSessionCookie("synthetic-chatgpt-session-cookie")
1146: 
--- private actor AppModelChatGPTUsageServiceStub
1238:     func exists(account: String) async -> Bool {
1239:         true
1240:     }
1241: }
1242: 
1243: private actor AppModelChatGPTUsageServiceStub: ChatGPTUsageServiceProtocol {
1244:     private let fetchUsageResult: Result<ChatGPTUsageData, Error>
1245:     private let validateResult: Bool
1246:     private(set) var fetchUsageCallCount = 0
1247: 
1248:     init(fetchUsageResult: Result<ChatGPTUsageData, Error>, validateResult: Bool) {
1249:         self.fetchUsageResult = fetchUsageResult
1250:         self.validateResult = validateResult
1251:     }
