618:             rows: [.init(label: "Codex Tasks", usedPercent: 42, resetAt: nil)],
619:             lastUpdated: Date(timeIntervalSince1970: 0)
620:         )
621:         let expectedGeminiUsage = GeminiUsageData(
622:             label: "Gemini API quota",
623:             usedPercent: 12,
624:             resetAt: nil,
625:             lastUpdated: Date(timeIntervalSince1970: 0)
626:         )
627:         let usageService = UsageServiceStub(fetchUsageResult: .success(expectedClaudeUsage))
628:         let chatGPTUsageService = AppModelChatGPTUsageServiceStub(
629:             fetchUsageResult: .success(expectedChatGPTUsage),
630:             validateResult: true
631:         )
632:         let geminiUsageService = AppModelGeminiUsageServiceStub(
633:             fetchUsageResult: .success(expectedGeminiUsage),
634:             validateResult: true
635:         )
636:         let appModel = AppModel(
637:             settingsRepository: SettingsRepositoryFake(),
638:             keychainRepository: KeychainRepositoryFake(),
639:             usageService: usageService,
640:             chatGPTUsageService: chatGPTUsageService,
641:             geminiUsageService: geminiUsageService,
642:             notificationService: NotificationServiceSpy()
643:         )
644: 
645:         appModel.hasChatGPTSessionCookie = true
646:         appModel.settings.isChatGPTUsageShown = true
647:         appModel.hasGeminiAPIKey = true
648: 
649:         await appModel.refreshConfiguredUsageProviders(forceRefresh: true)
650: 
651:         let claudeFetchCountAfterProviderOnlyRefresh = await usageService.fetchUsageCallCount
652:         let chatGPTFetchCountAfterProviderOnlyRefresh = await chatGPTUsageService.fetchUsageCallCount
653:         let geminiFetchCountAfterProviderOnlyRefresh = await geminiUsageService.fetchUsageCallCount
