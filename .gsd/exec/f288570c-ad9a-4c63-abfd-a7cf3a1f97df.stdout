  79:     func bootstrap() async {
  80:         guard !isReady else { return }
  81:         settings = await settingsRepository.load()
  82:         hasLoadedSettings = true
  83: 
  84:         isSetupComplete = await keychainRepository.exists(account: "default")
  85:         hasChatGPTSessionCookie = await keychainRepository.exists(account: "chatgpt")
  86:         isReady = true
  87: 
  88:         if hasChatGPTSessionCookie && settings.isChatGPTUsageShown {
  89:             await refreshChatGPTUsage()
  90:         }
  91: 
  94:         }
  95: 
  96:         if isSetupComplete || hasChatGPTSessionCookie {
  97:             startRefreshLoop()
  98:         }
  99: 
 114:         }
 115:         isRefreshing = true
 116:         errorMessage = nil
 117: 
 118:         defer {
 119:             isLoading = false
 126:             await notificationService.evaluateThresholds(
 127:                 usageData: data,
 128:                 settings: settings
 129:             )
 130:         } catch {
 131:             errorMessage = error.localizedDescription
 132:         }
 133:     }
