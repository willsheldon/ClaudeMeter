 297:         !chatGPTSessionTokenPart0.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty
 298:         || !chatGPTSessionTokenPart1.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty
 299:         || !chatGPTFullCookieHeader.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty
 300:     }
 301: 
 302:     private var joinedChatGPTCookieInput: String {
 303:         let fullHeader = chatGPTFullCookieHeader.trimmingCharacters(in: .whitespacesAndNewlines)
 304:         if !fullHeader.isEmpty {
 305:             return fullHeader
 306:         }
 307: 
 308:         return [chatGPTSessionTokenPart0, chatGPTSessionTokenPart1]
 309:             .map { $0.trimmingCharacters(in: .whitespacesAndNewlines) }
 310:             .joined()
 311:     }
