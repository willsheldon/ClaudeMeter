   8: import Foundation
   9: 
  10: /// Actor-isolated repository for app settings persistence using UserDefaults
  11: actor SettingsRepository: SettingsRepositoryProtocol {
  12:     private let userDefaults: UserDefaults
  13:     private let settingsKey = "app_settings"
  14:     private let notificationStateKey = "notification_state"
  15: 
  16:     init(userDefaults: UserDefaults = .standard) {
  17:         self.userDefaults = userDefaults
  18:     }
  19: 
  20:     /// Load app settings from UserDefaults
  21:     func load() async -> AppSettings {
  22:         guard let data = userDefaults.data(forKey: settingsKey) else {
  23:             return .default
  24:         }
  25: 
  28: 
  29:         do {
  30:             return try decoder.decode(AppSettings.self, from: data)
  31:         } catch {
  32:             // If decoding fails, return default settings
  33:             return .default
  34:         }
  35:     }
  36: 
  37:     /// Save app settings to UserDefaults
  38:     func save(_ settings: AppSettings) async throws {
  39:         let encoder = JSONEncoder()
  40:         encoder.dateEncodingStrategy = .iso8601
  41: 
  42:         let data = try encoder.encode(settings)
  43:         userDefaults.set(data, forKey: settingsKey)
  44:     }
  45: 
  46:     /// Load notification state from UserDefaults
  47:     func loadNotificationState() async -> NotificationState {
  48:         guard let data = userDefaults.data(forKey: notificationStateKey) else {
  49:             return NotificationState()
  59:     }
  60: 
  61:     /// Save notification state to UserDefaults
  62:     func saveNotificationState(_ state: NotificationState) async throws {
  63:         let encoder = JSONEncoder()
  64:         let data = try encoder.encode(state)

