  11: /// Actor-isolated repository for secure Keychain operations
  12: actor KeychainRepository: KeychainRepositoryProtocol {
  13:     private let serviceName = "com.claudemeter.sessionkey"
  14: 
  15:     /// Save session key to Keychain with security attributes
  16:     func save(sessionKey: String, account: String) async throws {
  17:         guard let data = sessionKey.data(using: .utf8) else {
  18:             throw KeychainError.saveFailed(OSStatus: errSecParam)
  19:         }
  20: 
  21:         let query: [String: Any] = [
  28:         ]
  29: 
  30:         let status = SecItemAdd(query as CFDictionary, nil)
  31: 
  32:         if status == errSecDuplicateItem {
  33:             // Item already exists, update it instead
  34:             try await update(sessionKey: sessionKey, account: account)
  35:         } else if status != errSecSuccess {
  36:             throw KeychainError.saveFailed(OSStatus: status)
  37:         }
  38:     }
  39: 
  40:     /// Retrieve session key from Keychain
  41:     func retrieve(account: String) async throws -> String {
  42:         let query: [String: Any] = [
  43:             kSecClass as String: kSecClassGenericPassword,
  49: 
  50:         var item: CFTypeRef?
  51:         let status = SecItemCopyMatching(query as CFDictionary, &item)
  52: 
  53:         guard status == errSecSuccess,
  54:               let data = item as? Data,
  55:               let sessionKey = String(data: data, encoding: .utf8) else {
  56:             throw KeychainError.notFound
  57:         }
  58: 
  59:         return sessionKey
  60:     }
  61: 
  62:     /// Update existing session key in Keychain
  63:     func update(sessionKey: String, account: String) async throws {
  64:         guard let data = sessionKey.data(using: .utf8) else {
  65:             throw KeychainError.updateFailed(OSStatus: errSecParam)
  66:         }
  67: 
  68:         let query: [String: Any] = [
  76:         ]
  77: 
  78:         let status = SecItemUpdate(query as CFDictionary, attributes as CFDictionary)
  79: 
  80:         guard status == errSecSuccess else {
  81:             throw KeychainError.updateFailed(OSStatus: status)
  82:         }
  83:     }
  84: 
  85:     /// Delete session key from Keychain
  86:     func delete(account: String) async throws {
  87:         let query: [String: Any] = [
  88:             kSecClass as String: kSecClassGenericPassword,
  91:         ]
  92: 
  93:         let status = SecItemDelete(query as CFDictionary)
  94: 
  95:         guard status == errSecSuccess || status == errSecItemNotFound else {
  96:             throw KeychainError.deleteFailed(OSStatus: status)
  97:         }
  98:     }
  99: 
 100:     /// Check if session key exists for account
 101:     func exists(account: String) async -> Bool {
 102:         let query: [String: Any] = [
 103:             kSecClass as String: kSecClassGenericPassword,
 107:         ]
 108: 
 109:         let status = SecItemCopyMatching(query as CFDictionary, nil)
 110:         return status == errSecSuccess
 111:     }
 112: }

