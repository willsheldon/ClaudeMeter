## Pinemeter/Services/SessionKeyImportService.swift
   1: import Foundation
   2: import os
   3: import SweetCookieKit
   4: 
   5: /// Imports Claude session keys from local browser cookies.
   6: actor SessionKeyImportService: SessionKeyImportServiceProtocol {
   7:     private static let logger = Logger(subsystem: "com.pinemeter", category: "SessionKeyImportService")
   8: 
   9:     private let cookieClient: BrowserCookieClient
  10:     private let browserImportOrder: [Browser]
  11: 
  12:     init(
  13:         cookieClient: BrowserCookieClient = BrowserCookieClient(),
  14:         browserImportOrder: [Browser] = Browser.defaultImportOrder
  15:     ) {
  16:         self.cookieClient = cookieClient
  17:         self.browserImportOrder = browserImportOrder
  18:     }
  19: 
  20:     func importSessionKey() async throws -> ImportedSessionKey {
  21:         let query = BrowserCookieQuery(domains: ["claude.ai"], domainMatch: .suffix)
  22:         var sawAccessDenied = false
  23:         var sawSafariAccessDenied = false
  24:         var deniedKeychainBrowserName: String?
  25: 
  26:         for browser in browserImportOrder {
  27:             do {
  28:                 let sources = try cookieClient.records(matching: query, in: browser)
  29:                 for source in sources {
  30:                     if let imported = try importedSessionKey(from: source) {
  31:                         return imported
  32:                     }
  33:                 }
  34:             } catch let error as BrowserCookieError {
  35:                 switch error {
  36:                 case .accessDenied:
  37:                     sawAccessDenied = true
  38:                     if browser == .safari {
  39:                         sawSafariAccessDenied = true
  40:                     } else if browser.usesKeychainForCookieDecryption {
  41:                         deniedKeychainBrowserName = browser.displayName
  42:                     }
  43:                 case .notFound, .loadFailed:
  44:                     break
  45:                 }
  46:                 Self.logger.debug("Browser cookie import failed for \(browser.displayName): \(error.localizedDescription)")
  47:             } catch {
  48:                 Self.logger.debug("Browser cookie import failed for \(browser.displayName): \(error.localizedDescription)")
  49:             }
  50:         }
  51: 
  52:         if let deniedKeychainBrowserName {
  53:             throw SessionKeyImportError.browserKeychainAccessDenied(deniedKeychainBrowserName)
  54:         }
  55:         if sawSafariAccessDenied {
  56:             throw SessionKeyImportError.safariAccessDenied
  57:         }
  58:         if sawAccessDenied {
  59:             throw SessionKeyImportError.accessDenied
  60:         }
  61:         throw SessionKeyImportError.noSessionKeyFound
  62:     }
  63: 
  64:     private func importedSessionKey(from source: BrowserCookieStoreRecords) throws -> ImportedSessionKey? {
  65:         guard let cookie = source.records.first(where: { $0.name == "sessionKey" }) else {
  66:             return nil
  67:         }
  68: 
  69:         let sessionKey = try SessionKey(cookie.value)
  70:         return ImportedSessionKey(
  71:             value: sessionKey.value,
  72:             sourceDescription: source.label
  73:         )
  74:     }
  76: 
  77: private extension Browser {
  78:     var usesKeychainForCookieDecryption: Bool {
  79:         switch self {
  80:         case .safari, .firefox, .zen:
  81:             return false

## Pinemeter/Services/UsageService.swift
  11: /// Actor-isolated usage service with retry logic
  12: actor UsageService: UsageServiceProtocol {
  13:     private static let logger = Logger(subsystem: "com.pinemeter", category: "UsageService")
  14:     private let networkService: NetworkServiceProtocol
  15:     private let cacheRepository: CacheRepositoryProtocol
  16:     private let keychainRepository: KeychainRepositoryProtocol
  17:     private let settingsRepository: SettingsRepositoryProtocol
  18: 
  19:     private let maxRetries = Constants.Network.maxRetries
  20:     private let baseURL = "https://claude.ai/api"
  23:         networkService: NetworkServiceProtocol,
  24:         cacheRepository: CacheRepositoryProtocol,
  25:         keychainRepository: KeychainRepositoryProtocol,
  26:         settingsRepository: SettingsRepositoryProtocol
  27:     ) {
  28:         self.networkService = networkService
  29:         self.cacheRepository = cacheRepository
  30:         self.keychainRepository = keychainRepository
  31:         self.settingsRepository = settingsRepository
  32:     }
  33: 
  34:     /// Fetch usage data with cache integration and exponential backoff retry
  35:     func fetchUsage(forceRefresh: Bool = false) async throws -> UsageData {
  36:         let sessionKeyString: String
  37:         do {
  38:             sessionKeyString = try await keychainRepository.retrieve(account: "default")
  39:         } catch KeychainError.notFound {
  40:             throw AppError.noSessionKey
  41:         } catch let error as KeychainError {
  42:             throw AppError.keychainError(error)
  43:         }
  44: 
  45:         let sessionKey = try SessionKey(sessionKeyString)
  46: 
  47:         // Clear cache if force refresh is requested
  48:         if forceRefresh {
  56: 
  57:         // Get organization ID
  58:         let settings = await settingsRepository.load()
  59:         let organizationId: UUID
  60: 
  61:         if let cachedOrgId = settings.cachedOrganizationId {
  62:             organizationId = cachedOrgId
  63:         } else if let orgId = sessionKey.organizationId {
  64:             organizationId = orgId
  65:         } else {
  66:             // Fetch organizations to get ID
  69:             guard let chatOrg = orgs.first(where: { $0.hasChatCapability }) ?? orgs.first,
  70:                   let uuid = chatOrg.organizationUUID else {
  71:                 throw AppError.organizationNotFound
  72:             }
  73:             organizationId = uuid
  74:         }
  75: 
  76:         // Fetch usage data with retry logic
  77:         var lastError: Error?
  78: 
  79:         for attempt in 0..<maxRetries {
  80:             do {
  82:                     "\(baseURL)/organizations/\(organizationId)/usage",
  83:                     method: .get,
  84:                     sessionKey: sessionKey.value
  85:                 )
  86: 
  87:                 let usageData = try response.toDomain()
  92:                 return usageData
  93: 
  94:             } catch NetworkError.networkUnavailable {
  95:                 Self.logger.warning("Network unavailable (attempt \(attempt + 1)/\(self.maxRetries))")
  96:                 lastError = NetworkError.networkUnavailable
  97:                 let delay = pow(Constants.Network.backoffBase, Double(attempt))
  98:                 try await Task.sleep(for: .seconds(delay))
  99:             } catch NetworkError.rateLimitExceeded {
 100:                 // Rate limit hit - use longer exponential backoff
 101:                 Self.logger.warning("Rate limit exceeded (attempt \(attempt + 1)/\(self.maxRetries))")
 102:                 lastError = NetworkError.rateLimitExceeded
 103:                 let delay = pow(Constants.Network.rateLimitBackoffBase, Double(attempt))
 104:                 try await Task.sleep(for: .seconds(delay))
 105:             } catch NetworkError.authenticationFailed {
 106:                 Self.logger.error("Authentication failed - session key invalid")
 107:                 throw AppError.sessionKeyInvalid
 108:             } catch let error as URLError where error.code == .timedOut ||
 109:                                                error.code == .cannotConnectToHost ||
 110:                                                error.code == .networkConnectionLost ||
 111:                                                error.code == .notConnectedToInternet {
 112:                 // Retry on timeout and connection errors
 113:                 Self.logger.warning("URL error: \(error.localizedDescription) (attempt \(attempt + 1)/\(self.maxRetries))")
 114:                 lastError = error
 115:                 let delay = pow(Constants.Network.backoffBase, Double(attempt))
 116:                 try await Task.sleep(for: .seconds(delay))
 117:             } catch {
 118:                 Self.logger.error("API request failed: \(error.localizedDescription)")
 119:                 throw AppError.networkError(error as? NetworkError ?? .invalidResponse)
 120:             }
 121:         }
 122: 
 128: 
 129:         Self.logger.error("All retries failed, no cached data available")
 130:         throw AppError.networkError(lastError as? NetworkError ?? .networkUnavailable)
 131:     }
 132: 
