 136: 
 137:     func refreshChatGPTUsage() async {
 138:         if !hasChatGPTSessionCookie {
 139:             hasChatGPTSessionCookie = await keychainRepository.exists(account: "chatgpt")
 140:         }
 141:         guard hasChatGPTSessionCookie else {
 142:             chatGPTUsageData = nil
 143:             return
 144:         }
 146: 
 147:         isRefreshingChatGPT = true
 148:         chatGPTErrorMessage = nil
 149: 
 150:         defer {
 151:             isRefreshingChatGPT = false
 153: 
 154:         do {
 155:             let sessionCookie = try await keychainRepository.retrieve(account: "chatgpt")
 156:             chatGPTUsageData = try await chatGPTUsageService.fetchUsage(sessionCookie: sessionCookie)
 157:         } catch {
 158:             chatGPTUsageData = nil
 159:             chatGPTErrorMessage = error.localizedDescription
 160:         }
 161:     }
 162: 
 163:     func loadChatGPTSessionCookie() async -> String? {
 164:         do {
 165:             return try await keychainRepository.retrieve(account: "chatgpt")
 166:         } catch {
 167:             return nil
 168:         }
 169:     }
 170: 
 171:     func validateAndSaveChatGPTSessionCookie(_ rawValue: String) async throws -> Bool {
 172:         let trimmedCookie = rawValue.trimmingCharacters(in: .whitespacesAndNewlines)
 173:         guard !trimmedCookie.isEmpty else { return false }
 174: 
 175:         let isValid = try await chatGPTUsageService.validateSessionCookie(trimmedCookie)
 176:         guard isValid else { return false }
 177: 
 178:         try await keychainRepository.save(sessionKey: trimmedCookie, account: "chatgpt")
 179:         hasChatGPTSessionCookie = true
 180:         settings.isChatGPTUsageShown = true
 181:         await refreshChatGPTUsage()
 182:         return true
 183:     }
 184: 
 185:     func clearChatGPTSessionCookie() async throws {
 186:         try await keychainRepository.delete(account: "chatgpt")
 187:         hasChatGPTSessionCookie = false
 188:         settings.isChatGPTUsageShown = false
 189:         chatGPTUsageData = nil
 190:         chatGPTErrorMessage = nil
 191:     }
 192: 
 193:     // MARK: - Session Key
 194: 
 195:     func loadSessionKey() async -> String? {
 196:         do {
 197:             return try await keychainRepository.retrieve(account: "default")
 198:         } catch KeychainError.notFound {
 199:             return nil
 200:         } catch {
 201:             return nil
 203:     }
 204: 
 205:     func validateAndSaveSessionKey(_ rawValue: String) async throws -> Bool {
 206:         let sessionKey = try SessionKey(rawValue)
 207:         let isValid = try await usageService.validateSessionKey(sessionKey)
 208: 
 209:         guard isValid else {
 210:             return false
 211:         }
 212: 
 213:         let organizations = try await usageService.fetchOrganizations(sessionKey: sessionKey)
 214:         // Prefer organization with chat capability (Claude.ai usage), fall back to first
 215:         guard let chatOrg = organizations.first(where: { $0.hasChatCapability }) ?? organizations.first,
 216:               let orgUUID = chatOrg.organizationUUID else {
 217:             throw AppError.organizationNotFound
 218:         }
 219: 
 220:         try await keychainRepository.save(sessionKey: sessionKey.value, account: "default")
 221: 
 222:         settings.cachedOrganizationId = orgUUID
 223:         settings.isFirstLaunch = false
 224:         isSetupComplete = true
 225: 
 226:         await refreshUsage(forceRefresh: true)
 230:     }
 231: 
 232:     func importAndSaveSessionKey() async throws -> ImportedSessionKey {
 233:         let imported = try await sessionKeyImportService.importSessionKey()
 234:         let isValid = try await validateAndSaveSessionKey(imported.value)
 235: 
 236:         guard isValid else {
 237:             throw SessionKeyImportError.invalidImportedSessionKey
 238:         }
 239: 
 240:         return imported
 241:     }
 242: 
 243:     func clearSessionKey() async throws {
 244:         try await keychainRepository.delete(account: "default")
 245:         settings.cachedOrganizationId = nil
 246:         settings.isFirstLaunch = true
 247:         isSetupComplete = false
 248:         usageData = nil
 249:         errorMessage = nil
 250:         refreshTask?.cancel()
 251:     }
 252: 
 256:         let hasPermission = await notificationService.checkNotificationPermissions()
 257:         if !hasPermission {
 258:             _ = try? await notificationService.requestAuthorization()
 259:         }
 260:     }
 261: 
 274:     // MARK: - Private
 275: 
 276:     private func scheduleSettingsSave(previous: AppSettings) {
 277:         settingsSaveTask?.cancel()
 278:         settingsSaveTask = Task {
 279:             try? await settingsRepository.save(settings)
 280:         }
 281: 
 282:         if previous.refreshInterval != settings.refreshInterval {
 283:             startRefreshLoop()
 284:         }
 285:     }
 287:     private func startRefreshLoop() {
 288:         refreshTask?.cancel()
 289:         guard isSetupComplete || hasChatGPTSessionCookie else { return }
 290: 
 291:         let interval = Duration.seconds(Int(settings.refreshInterval))
 292:         refreshTask = Task { [weak self] in
 293:             guard let self else { return }
 294:             while !Task.isCancelled {
 297:                     await self.refreshUsage()
 298:                 }
 299:                 if self.hasChatGPTSessionCookie && self.settings.isChatGPTUsageShown {
 300:                     await self.refreshChatGPTUsage()
 301:                 }
 302:             }
 312:                     await self.refreshUsage(forceRefresh: true)
 313:                 }
 314:                 if self.hasChatGPTSessionCookie && self.settings.isChatGPTUsageShown {
 315:                     await self.refreshChatGPTUsage()
 316:                 }
 317:             }
 327:         usageData: UsageData?,
 328:         isSetupComplete: Bool,
 329:         errorMessage: String?,
 330:         isLoading: Bool
 331:     ) {
 332:         self.usageData = usageData
 333:         self.isSetupComplete = isSetupComplete
 334:         self.errorMessage = errorMessage
 335:         self.isLoading = isLoading
 336:         self.isReady = true
 337:         self.hasLoadedSettings = true
 338:         // Don't start refresh loop or wake observer in demo mode
 339:     }
 340:     #endif

