 137:             sessionKeyString = try await keychainRepository.retrieve(account: "default")
 138:         } catch KeychainError.notFound {
 139:             throw AppError.noSessionKey
 140:         } catch let error as KeychainError {
 141:             throw AppError.keychainError(error)
 142:         }
 143: 
 144:         let sessionKey = try SessionKey(sessionKeyString)
 145:         return try await fetchOrganizations(sessionKey: sessionKey)
 146:     }
