739:     func test_refreshConfiguredUsageProviders_refreshesOnlyVisibleConfiguredProviders() async {
740:         let expectedClaudeUsage = makeUsageData(percentage: TestConstants.sessionPercentage)
741:         let expectedChatGPTUsage = ChatGPTUsageData(
742:             rows: [.init(label: "Codex Tasks", usedPercent: 42, resetAt: nil)],
743:             lastUpdated: Date(timeIntervalSince1970: 0)
744:         )
745:         let expectedGeminiUsage = GeminiUsageData(
746:             label: "Gemini API quota",
747:             usedPercent: 12,
748:             resetAt: nil,
749:             lastUpdated: Date(timeIntervalSince1970: 0)
750:         )
751:         let usageService = UsageServiceStub(fetchUsageResult: .success(expectedClaudeUsage))
752:         let chatGPTUsageService = AppModelChatGPTUsageServiceStub(
753:             fetchUsageResult: .success(expectedChatGPTUsage),
754:             validateResult: true
755:         )
756:         let geminiUsageService = AppModelGeminiUsageServiceStub(
757:             fetchUsageResult: .success(expectedGeminiUsage),
758:             validateResult: true
759:         )
760:         let appModel = AppModel(
761:             settingsRepository: SettingsRepositoryFake(),
762:             keychainRepository: KeychainRepositoryFake(),
763:             usageService: usageService,
764:             chatGPTUsageService: chatGPTUsageService,
765:             geminiUsageService: geminiUsageService,
766:             notificationService: NotificationServiceSpy()
767:         )
768: 
769:         appModel.hasChatGPTSessionCookie = true
770:         appModel.settings.isChatGPTUsageShown = true
771:         appModel.hasGeminiAPIKey = true
772: 
773:         await appModel.refreshConfiguredUsageProviders(forceRefresh: true)
774: 
775:         let claudeFetchCountAfterProviderOnlyRefresh = await usageService.fetchUsageCallCount
776:         let chatGPTFetchCountAfterProviderOnlyRefresh = await chatGPTUsageService.fetchUsageCallCount
777:         let geminiFetchCountAfterProviderOnlyRefresh = await geminiUsageService.fetchUsageCallCount
778: 
779:         XCTAssertNil(appModel.usageData)
780:         XCTAssertEqual(appModel.chatGPTUsageData, expectedChatGPTUsage)
781:         XCTAssertEqual(appModel.geminiUsageData, expectedGeminiUsage)
782:         XCTAssertEqual(claudeFetchCountAfterProviderOnlyRefresh, 0)
783:         XCTAssertEqual(chatGPTFetchCountAfterProviderOnlyRefresh, 1)
784:         XCTAssertEqual(geminiFetchCountAfterProviderOnlyRefresh, 1)
785: 
786:         appModel.isSetupComplete = true
787: 
788:         await appModel.refreshConfiguredUsageProviders(forceRefresh: true)
789: 
790:         let claudeFetchCountAfterAllRefresh = await usageService.fetchUsageCallCount
791:         let claudeForceRefreshValues = await usageService.forceRefreshValues
792:         let chatGPTFetchCountAfterAllRefresh = await chatGPTUsageService.fetchUsageCallCount
793:         let geminiFetchCountAfterAllRefresh = await geminiUsageService.fetchUsageCallCount
794: 
795:         XCTAssertEqual(appModel.usageData, expectedClaudeUsage)
796:         XCTAssertEqual(appModel.chatGPTUsageData, expectedChatGPTUsage)
797:         XCTAssertEqual(appModel.geminiUsageData, expectedGeminiUsage)
798:         XCTAssertEqual(claudeFetchCountAfterAllRefresh, 1)
799:         XCTAssertEqual(claudeForceRefreshValues, [true])
800:         XCTAssertEqual(chatGPTFetchCountAfterAllRefresh, 2)
801:         XCTAssertEqual(geminiFetchCountAfterAllRefresh, 2)
802:     }
