1572: private func makeUsageData(percentage: Double) -> UsageData {
1573:     let resetDate = Date().addingTimeInterval(TestConstants.oneHourInterval)
1574:     let sessionUsage = UsageLimit(utilization: percentage, resetAt: resetDate)
1575:     let weeklyUsage = UsageLimit(utilization: TestConstants.weeklyPercentage, resetAt: resetDate)
1576: 
1577:     return UsageData(
1578:         sessionUsage: sessionUsage,
1579:         weeklyUsage: weeklyUsage,
1580:         sonnetUsage: nil,
1581:         lastUpdated: Date()
1582:     )
1583: }
