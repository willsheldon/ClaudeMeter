29:     // MARK: - Dependencies
30: 
31:     @ObservationIgnored private let settingsRepository: SettingsRepositoryProtocol
32:     @ObservationIgnored private let keychainRepository: KeychainRepositoryProtocol
33:     @ObservationIgnored private let usageService: UsageServiceProtocol
34:     @ObservationIgnored private let chatGPTUsageService: ChatGPTUsageServiceProtocol
35:     @ObservationIgnored private let notificationService: NotificationServiceProtocol
36:     @ObservationIgnored private let sessionKeyImportService: SessionKeyImportServiceProtocol
37: 
38:     // MARK: - Private
39: 
40:     @ObservationIgnored private var refreshTask: Task<Void, Never>?
41:     @ObservationIgnored private var settingsSaveTask: Task<Void, Never>?
42:     @ObservationIgnored private var wakeTask: Task<Void, Never>?
43:     @ObservationIgnored private var hasLoadedSettings: Bool = false
44:     @ObservationIgnored private let refreshClock = ContinuousClock()
45: 
46:     // MARK: - Initialization
47: 
48:     init(
49:         settingsRepository: SettingsRepositoryProtocol = SettingsRepository(),
50:         keychainRepository: KeychainRepositoryProtocol = KeychainRepository(),
51:         usageService: UsageServiceProtocol? = nil,
52:         chatGPTUsageService: ChatGPTUsageServiceProtocol? = nil,
53:         notificationService: NotificationServiceProtocol? = nil,
54:         sessionKeyImportService: SessionKeyImportServiceProtocol = SessionKeyImportService()
55:     ) {
56:         self.settingsRepository = settingsRepository
57:         self.keychainRepository = keychainRepository
58:         self.sessionKeyImportService = sessionKeyImportService
59: 
60:         let networkService = WebViewNetworkService()
61:         let cacheRepository = CacheRepository()
62:         let usageService = usageService ?? UsageService(
63:             networkService: networkService,
64:             cacheRepository: cacheRepository,
65:             keychainRepository: keychainRepository,
66:             settingsRepository: settingsRepository
67:         )
68:         self.usageService = usageService
69:         self.chatGPTUsageService = chatGPTUsageService ?? ChatGPTUsageService()
70:         self.notificationService = notificationService ?? NotificationService(
71:             settingsRepository: settingsRepository
72:         )
73: 
74:         self.notificationService.setupDelegate()
75:     }
