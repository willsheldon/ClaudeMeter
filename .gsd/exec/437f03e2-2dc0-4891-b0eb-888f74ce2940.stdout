.github/workflows/release.yml:126: - name: Notarize app
.github/workflows/release.yml:132: APP_PATH="build/Build/Products/Release/Pinemeter.app"
.github/workflows/release.yml:136: /usr/bin/ditto -c -k --keepParent "$APP_PATH" "$RUNNER_TEMP/Pinemeter-notarize.zip"
.github/workflows/release.yml:138: echo "Submitting for notarization..."
.github/workflows/release.yml:139: SUBMIT_OUTPUT=$(xcrun notarytool submit "$RUNNER_TEMP/Pinemeter-notarize.zip" \
.github/workflows/release.yml:150: # Check if notarization succeeded
