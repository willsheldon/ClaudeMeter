.github/workflows/release.yml:170: rm -f $RUNNER_TEMP/AuthKey.p8 $RUNNER_TEMP/Pinemeter-notarize.zip
.github/workflows/release.yml:174: cd build/Build/Products/Release
.github/workflows/release.yml:179: - name: Create GitHub Release
