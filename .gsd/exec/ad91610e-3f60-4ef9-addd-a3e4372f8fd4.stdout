609:     func test_refreshConfiguredUsageProviders_refreshesOnlyVisibleConfiguredProviders() async {
610:         let expectedClaudeUsage = makeUsageData(percentage: TestConstants.sessionPercentage)
611:         let expectedChatGPTUsage = ChatGPTUsageData(
612:             rows: [.init(label: "Codex Tasks", usedPercent: 42, resetAt: nil)],
613:             lastUpdated: Date(timeIntervalSince1970: 0)
614:         )
615:         let usageService = UsageServiceStub(fetchUsageResult: .success(expectedClaudeUsage))
616:         let chatGPTUsageService = AppModelChatGPTUsageServiceStub(
617:             fetchUsageResult: .success(expectedChatGPTUsage),
618:             validateResult: true
619:         )
620:         let appModel = AppModel(
621:             settingsRepository: SettingsRepositoryFake(),
622:             keychainRepository: KeychainRepositoryFake(),
623:             usageService: usageService,
624:             chatGPTUsageService: chatGPTUsageService,
625:             notificationService: NotificationServiceSpy()
626:         )
627: 
628:         appModel.hasChatGPTSessionCookie = true
629:         appModel.settings.isChatGPTUsageShown = true
630: 
631:         await appModel.refreshConfiguredUsageProviders(forceRefresh: true)
632: 
633:         let claudeFetchCountAfterChatGPTOnlyRefresh = await usageService.fetchUsageCallCount
634:         let chatGPTFetchCountAfterChatGPTOnlyRefresh = await chatGPTUsageService.fetchUsageCallCount
635: 
636:         XCTAssertNil(appModel.usageData)
637:         XCTAssertEqual(appModel.chatGPTUsageData, expectedChatGPTUsage)
638:         XCTAssertEqual(claudeFetchCountAfterChatGPTOnlyRefresh, 0)
639:         XCTAssertEqual(chatGPTFetchCountAfterChatGPTOnlyRefresh, 1)
640: 
641:         appModel.isSetupComplete = true
642: 
643:         await appModel.refreshConfiguredUsageProviders(forceRefresh: true)
644: 
645:         let claudeFetchCountAfterBothRefresh = await usageService.fetchUsageCallCount
646:         let claudeForceRefreshValues = await usageService.forceRefreshValues
647:         let chatGPTFetchCountAfterBothRefresh = await chatGPTUsageService.fetchUsageCallCount
648: 
649:         XCTAssertEqual(appModel.usageData, expectedClaudeUsage)
650:         XCTAssertEqual(appModel.chatGPTUsageData, expectedChatGPTUsage)
651:         XCTAssertEqual(claudeFetchCountAfterBothRefresh, 1)
652:         XCTAssertEqual(claudeForceRefreshValues, [true])
653:         XCTAssertEqual(chatGPTFetchCountAfterBothRefresh, 2)
654:     }
