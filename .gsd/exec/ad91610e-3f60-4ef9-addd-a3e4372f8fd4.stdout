1008:     func test_chatGPTCredentialLifecycle_recoversFromInvalidClearAndReacquire() async throws {
1009:         let expectedUsage = ChatGPTUsageData(
1010:             rows: [.init(label: "Codex Tasks", usedPercent: 24, resetAt: nil)],
1011:             lastUpdated: Date(timeIntervalSince1970: 0)
1012:         )
1013:         let settingsRepository = SettingsRepositoryFake()
1014:         let keychainRepository = KeychainRepositoryFake()
1015:         let notificationService = NotificationServiceSpy()
1016:         let chatGPTSessionRepository = AppModelChatGPTSessionRepositoryFake()
1017:         let invalidChatGPTUsageService = AppModelChatGPTUsageServiceStub(
1018:             fetchUsageResult: .success(expectedUsage),
1019:             validateResult: false
1020:         )
1021:         let invalidModel = AppModel(
1022:             settingsRepository: settingsRepository,
1023:             keychainRepository: keychainRepository,
1024:             usageService: UsageServiceStub(fetchUsageResult: .failure(TestError(message: TestConstants.unexpectedErrorMessage))),
1025:             chatGPTUsageService: invalidChatGPTUsageService,
1026:             chatGPTSessionRepository: chatGPTSessionRepository,
1027:             notificationService: notificationService
1028:         )
1029: 
1030:         let rejected = try await invalidModel.validateAndSaveChatGPTSessionCookie("synthetic-chatgpt-session-cookie")
1031: 
1032:         XCTAssertFalse(rejected)
1033:         XCTAssertFalse(invalidModel.hasChatGPTSessionCookie)
1034:         XCTAssertEqual(invalidModel.chatGPTCredentialState.health, .invalid)
1035:         XCTAssertEqual(invalidModel.chatGPTCredentialState.failureCategory, .providerRejected)
1036:         do {
1037:             _ = try await chatGPTSessionRepository.load(account: ChatGPTUsageService.defaultSessionAccount)
1038:             XCTFail("Expected missing ChatGPT session after invalid validation")
1039:         } catch ChatGPTSessionRepositoryError.notFound {
1040:             // Expected
1041:         } catch {
1042:             XCTFail("Unexpected error: \(error)")
1043:         }
1044: 
1045:         let validChatGPTUsageService = AppModelChatGPTUsageServiceStub(
1046:             fetchUsageResult: .success(expectedUsage),
1047:             validateResult: true
1048:         )
1049:         let setupModel = AppModel(
1050:             settingsRepository: settingsRepository,
1051:             keychainRepository: keychainRepository,
1052:             usageService: UsageServiceStub(fetchUsageResult: .failure(TestError(message: TestConstants.unexpectedErrorMessage))),
1053:             chatGPTUsageService: validChatGPTUsageService,
1054:             chatGPTSessionRepository: chatGPTSessionRepository,
1055:             notificationService: notificationService
1056:         )
1057: 
1058:         let acquired = try await setupModel.validateAndSaveChatGPTSessionCookie("synthetic-chatgpt-session-cookie")
1059: 
1060:         XCTAssertTrue(acquired)
1061:         XCTAssertTrue(setupModel.hasChatGPTSessionCookie)
1062:         XCTAssertTrue(setupModel.settings.isChatGPTUsageShown)
1063:         let savedChatGPTSession = try await chatGPTSessionRepository.load(account: ChatGPTUsageService.defaultSessionAccount)
1064: 
1065:         XCTAssertEqual(setupModel.chatGPTCredentialState.health, .valid)
1066:         XCTAssertEqual(setupModel.chatGPTUsageData, expectedUsage)
1067:         XCTAssertEqual(savedChatGPTSession.sessionCookie, "synthetic-chatgpt-session-cookie")
1068: 
1069:         var reuseSettings = AppSettings.default
1070:         reuseSettings.isChatGPTUsageShown = true
1071:         try await settingsRepository.save(reuseSettings)
1072:         let reuseModel = AppModel(
1073:             settingsRepository: settingsRepository,
1074:             keychainRepository: keychainRepository,
1075:             usageService: UsageServiceStub(fetchUsageResult: .failure(TestError(message: TestConstants.unexpectedErrorMessage))),
1076:             chatGPTUsageService: validChatGPTUsageService,
1077:             chatGPTSessionRepository: chatGPTSessionRepository,
1078:             notificationService: notificationService
1079:         )
1080: 
1081:         await reuseModel.bootstrap()
1082: 
1083:         XCTAssertTrue(reuseModel.hasChatGPTSessionCookie)
1084:         XCTAssertEqual(reuseModel.chatGPTCredentialState.health, .valid)
1085:         XCTAssertEqual(reuseModel.chatGPTUsageData, expectedUsage)
1086: 
1087:         try await setupModel.clearChatGPTSessionCookie()
