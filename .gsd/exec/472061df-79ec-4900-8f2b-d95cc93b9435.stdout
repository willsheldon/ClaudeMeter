.github/workflows/deploy-pages.yml:32:      - name: Fetch latest release version
.github/workflows/deploy-pages.yml:37:          RELEASE_TAG=$(gh release view --json tagName --jq '.tagName' 2>/dev/null || echo "")
.github/workflows/deploy-pages.yml:40:            echo "Found release version: $VERSION"
.github/workflows/deploy-pages.yml:43:            echo "No releases found, keeping default version"
.github/workflows/release.yml:7:  build-and-release:
.github/workflows/release.yml:49:          sed -i '' "s/MARKETING_VERSION = [^;]*/MARKETING_VERSION = ${{ steps.version.outputs.version }}/g" Pinemeter.xcodeproj/project.pbxproj
.github/workflows/release.yml:53:          sed -i '' "s/CURRENT_PROJECT_VERSION = [^;]*/CURRENT_PROJECT_VERSION = $BUILD_NUMBER/g" Pinemeter.xcodeproj/project.pbxproj
.github/workflows/release.yml:86:          xcodebuild clean build \
.github/workflows/release.yml:87:            -project Pinemeter.xcodeproj \
.github/workflows/release.yml:162:        uses: softprops/action-gh-release@v3
.github/workflows/release.yml:169:          prerelease: false
.github/workflows/release.yml:173:      - name: Update Homebrew tap
.github/workflows/release.yml:179:          git clone https://x-access-token:${TAP_TOKEN}@github.com/eddmann/homebrew-tap.git
.github/workflows/release.yml:180:          cd homebrew-tap
.github/workflows/release.yml:186:          git config user.email "github-actions[bot]@users.noreply.github.com"
