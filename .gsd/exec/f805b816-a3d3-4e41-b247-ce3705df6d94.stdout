95:         ]
96: 
97:         assertNoCredentialDisclosure(in: errors.map { $0.localizedDescription })
98:     }
99: 
100:     func test_networkServiceDiagnosticsDoNotLogResponseBodiesOrCredentialFragments() throws {
101:         let testFile = URL(fileURLWithPath: #filePath)
102:         let repositoryRoot = testFile.deletingLastPathComponent().deletingLastPathComponent()
103:         let networkServiceURL = repositoryRoot
104:             .appendingPathComponent("Pinemeter")
105:             .appendingPathComponent("Services")
106:             .appendingPathComponent("NetworkService.swift")
107:         let source = try String(contentsOf: networkServiceURL, encoding: .utf8)
108: 
109:         let prohibitedBodyLoggingPatterns = [
110:             "responseBody",
111:             "Response:",
112:             "String(data: data"
113:         ]
114: 
115:         for prohibitedPattern in prohibitedBodyLoggingPatterns {
116:             XCTAssertFalse(
117:                 source.contains(prohibitedPattern),
118:                 "NetworkService diagnostics must not log or construct response bodies: \(prohibitedPattern)"
119:             )
120:         }
121: 
122:         let diagnosticLines = source
123:             .split(separator: "\n", omittingEmptySubsequences: false)
124:             .filter { $0.contains("logger.") }
125:         let prohibitedDiagnosticFragments = [
126:             "Cookie:",
127:             "sessionKey",
128:             "Bearer",
129:             "responseBody"
130:         ]
131: 
132:         for diagnosticLine in diagnosticLines {
133:             for prohibitedFragment in prohibitedDiagnosticFragments {
134:                 XCTAssertFalse(
135:                     diagnosticLine.contains(prohibitedFragment),
136:                     "NetworkService diagnostic logs must not include credential-shaped fragments or response bodies: \(prohibitedFragment)"
137:                 )
138:             }
139:         }
140:     }
141: 
142:     private func assertNoCredentialDisclosure(in descriptions: [String], file: StaticString = #filePath, line: UInt = #line) {
143:         for description in descriptions {
144:             for forbiddenFragment in forbiddenCredentialFragments {
145:                 XCTAssertFalse(
146:                     description.contains(forbiddenFragment),
147:                     "User-facing error descriptions must not include credential-shaped fragments: \(forbiddenFragment)",
148:                     file: file,
149:                     line: line
150:                 )
151:             }
152:         }
153:     }
154: }
155: 
156: private struct SyntheticCredentialError: LocalizedError {
157:     var errorDescription: String? {
158:         "Synthetic upstream failure with sk-ant-test-synthetic-session-key, Cookie: __Secure-next-auth.session-token=synthetic-cookie, Bearer synthetic-access-token, access-token-synthetic-secret"
159:     }
160: }
