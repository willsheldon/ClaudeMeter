2:# Demo mode launcher for ClaudeMeter (macOS)
8:SCHEME="ClaudeMeter"
22:echo "=== ClaudeMeter Demo Mode Launcher ==="
50:xcodebuild -project "$PROJECT_DIR/ClaudeMeter.xcodeproj" \
55:xcodebuild -project "$PROJECT_DIR/ClaudeMeter.xcodeproj" \
62:APP_PATH=$(find "$BUILD_DIR/Build/Products" -name "ClaudeMeter.app" -type d 2>/dev/null | head -1)
73:pkill -f "ClaudeMeter.app" 2>/dev/null || true
