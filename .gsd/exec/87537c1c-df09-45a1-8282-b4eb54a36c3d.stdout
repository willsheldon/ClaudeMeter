142:     func test_clearCredentialWorkflowCopyIsProviderSpecificAndCredentialFree() {
143:         let statuses = [
144:             AppProviderCredentialStatus(
145:                 state: CredentialState(
146:                     identity: CredentialIdentity(provider: .claude, kind: .sessionKey),
147:                     health: .invalid,
148:                     failureCategory: .providerRejected,
149:                     checkedAt: Date(timeIntervalSince1970: 0)
150:                 ),

---CUT---

151:                 actions: [.init(kind: .clear)]
152:             ),
153:             AppProviderCredentialStatus(
154:                 state: CredentialState(
155:                     identity: CredentialIdentity(provider: .chatGPT, kind: .sessionCookie),
156:                     health: .invalid,
157:                     failureCategory: .providerRejected,
158:                     checkedAt: Date(timeIntervalSince1970: 0)
159:                 ),
160:                 actions: [.init(kind: .clear)]
161:             )
162:         ]
163:         let forbiddenFragments = [
164:             "sk-ant-test-reset-sentinel",
165:             "__Secure-next-auth.session-token=synthetic-reset-cookie",
166:             "Cookie:",
167:             "Bearer synthetic-reset-access-token"
168:         ]
169: 
170:         XCTAssertEqual(statuses.map(\.providerName), ["Claude", "ChatGPT"])
171:         XCTAssertEqual(statuses.map(\.credentialName), ["Claude session key", "ChatGPT session cookie"])
172:         XCTAssertEqual(statuses.map { $0.actions.map(\.displayTitle) }, [["Clear"], ["Clear"]])
173: 
174:         let userFacingCopy = statuses.flatMap { status in
175:             [
176:                 status.providerName,
177:                 status.credentialName,
178:                 status.setupPromptTitle,
179:                 status.setupPromptDescription,
180:                 status.setupAccessibilityLabel
181:             ] + status.actions.map(\.displayTitle)
182:         }
183: 
184:         for copy in userFacingCopy {
185:             for forbiddenFragment in forbiddenFragments {
186:                 XCTAssertFalse(
187:                     copy.contains(forbiddenFragment),
188:                     "Credential reset workflow copy must not expose synthetic credential material: \(forbiddenFragment)"
189:                 )
190:             }
191:         }
192:     }
