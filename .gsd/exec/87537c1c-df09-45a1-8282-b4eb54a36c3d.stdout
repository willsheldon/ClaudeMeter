194:     private func sourceContents(relativePath: String) throws -> String {
195:         let testFile = URL(fileURLWithPath: #filePath)
196:         let repositoryRoot = testFile.deletingLastPathComponent().deletingLastPathComponent()
197:         let sourceURL = relativePath.split(separator: "/").reduce(repositoryRoot) { url, component in
198:             url.appendingPathComponent(String(component))
199:         }
200:         return try String(contentsOf: sourceURL, encoding: .utf8)
201:     }
202: 
203: }

