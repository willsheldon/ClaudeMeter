4: final class ProviderErrorWorkflowTests: XCTestCase {
5:     func test_appError_noSessionKey_usesClaudeSpecificCredentialCopy() {
6:         XCTAssertEqual(AppError.noSessionKey.errorDescription, "No Claude session key found. Please complete setup.")
7:         XCTAssertEqual(AppError.noSessionKey.recoveryAction, "Complete Claude Setup")
8:     }
9: 
10:     func test_appError_sessionKeyInvalid_usesClaudeSpecificCredentialCopy() {
11:         XCTAssertEqual(AppError.sessionKeyInvalid.errorDescription, "Claude session key is invalid or expired. Please update in settings.")
12:         XCTAssertEqual(AppError.sessionKeyInvalid.recoveryAction, "Update Claude Session Key")
13:     }
14: 
15:     func test_networkAuthenticationFailed_usesClaudeSpecificCredentialCopy() {
16:         XCTAssertEqual(NetworkError.authenticationFailed.errorDescription, "Claude session key is invalid or expired")
17:     }
18: 
19:     func test_claudeRecoveryCopy_detectsOnlyClaudeCredentialAuthenticationMessages() {
20:         XCTAssertTrue(ClaudeCredentialRecoveryCopy.shouldShowUpdateButton(for: "Claude session key is invalid or expired"))
21:         XCTAssertTrue(ClaudeCredentialRecoveryCopy.shouldShowUpdateButton(for: "Claude authentication failed"))
22: 
23:         XCTAssertFalse(ClaudeCredentialRecoveryCopy.shouldShowUpdateButton(for: "ChatGPT session token is invalid"))
24:         XCTAssertFalse(ClaudeCredentialRecoveryCopy.shouldShowUpdateButton(for: "ChatGPT authentication failed"))
25:         XCTAssertFalse(ClaudeCredentialRecoveryCopy.shouldShowUpdateButton(for: "Network timeout"))
26:     }
27: 
28:     func test_claudeRecoveryCopy_usesClaudeSpecificButtonLabel() {
29:         XCTAssertEqual(ClaudeCredentialRecoveryCopy.updateButtonTitle, "Update Claude Session Key")
30:     }
31: 
32:     func test_chatGPTUsageErrorsDoNotEchoCookieOrBearerTokenSentinels() {
33:         let forbiddenFragments = [
34:             "__Secure-next-auth.session-token=synthetic-cookie-redaction-sentinel",
35:             "synthetic-cookie-redaction-sentinel",
36:             "Bearer synthetic-access-token-redaction-sentinel",
37:             "synthetic-access-token-redaction-sentinel"
38:         ]
39:         let descriptions = [
40:             ChatGPTUsageError.missingSessionCookie.localizedDescription,
41:             ChatGPTUsageError.invalidSessionCookie.localizedDescription,
42:             ChatGPTUsageError.invalidResponse.localizedDescription,
43:             ChatGPTUsageError.httpError(statusCode: 401).localizedDescription,
44:             ChatGPTUsageError.networkUnavailable.localizedDescription
45:         ]
46: 
47:         for description in descriptions {
48:             for forbiddenFragment in forbiddenFragments {
49:                 XCTAssertFalse(
50:                     description.contains(forbiddenFragment),
51:                     "ChatGPT user-facing errors must not echo credential material: \(forbiddenFragment)"
52:                 )
53:             }
54:         }
55:     }
56: 
57:     func test_chatGPTInvalidCredentialStatusKeepsRecoveryProviderSpecificAndSanitized() {
58:         let status = AppProviderCredentialStatus(
59:             state: CredentialState(
60:                 identity: CredentialIdentity(provider: .chatGPT, kind: .sessionCookie),
61:                 health: .invalid,
62:                 failureCategory: .providerRejected,
63:                 checkedAt: Date(timeIntervalSince1970: 0)
64:             ),
65:             actions: [.init(kind: .reconnect), .init(kind: .clear)]
66:         )
67: 
68:         XCTAssertEqual(status.providerName, "ChatGPT")
69:         XCTAssertEqual(status.credentialName, "ChatGPT session cookie")
70:         XCTAssertEqual(status.setupPromptTitle, "Recover ChatGPT session cookie")
71:         XCTAssertEqual(status.setupPromptDescription, "Update the credential and try again.")
72:         XCTAssertEqual(status.actions.map { $0.displayTitle }, ["Reconnect", "Clear"])
73:         XCTAssertTrue(status.setupAccessibilityLabel.contains("ChatGPT session cookie status: Invalid"))
74:         XCTAssertFalse(status.setupAccessibilityLabel.contains("synthetic-chatgpt-session-cookie"))
75:     }
