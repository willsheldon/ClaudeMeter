111:     func test_setupProviderStatusCardsExposeSharedRepairAndClearActionsWithoutManualCredentials() throws {
112:         let settingsSource = try sourceContents(relativePath: "Pinemeter/Views/Settings/SettingsView.swift")
113:         let setupSource = try sourceContents(relativePath: "Pinemeter/Views/Setup/SetupWizardView.swift")
114: 
115:         XCTAssertTrue(setupSource.contains("private func providerCredentialStatusActions(for status: AppProviderCredentialStatus) -> some View"))
116:         XCTAssertTrue(setupSource.contains("let visibleActions = status.actions.filter { $0.kind != .reconnect }"))
117:         XCTAssertTrue(setupSource.contains("activeCredentialActionProvider"))
118:         XCTAssertTrue(setupSource.contains("await performProviderCredentialAction(kind, for: status)"))
119:         XCTAssertTrue(setupSource.contains("try await appModel.performProviderCredentialAction(kind, for: status.provider)"))
120:         XCTAssertTrue(setupSource.contains("Reconnecting credentials from the signed-in browser session."))
121:         XCTAssertFalse(setupSource.contains("await importProviderSessions(from: .defaultBrowser)"))
122:         XCTAssertFalse(setupSource.contains("await repairClaudeSessionKey()"))
123:         XCTAssertFalse(setupSource.contains("await clearSavedCredential(for: status.provider)"))
124:         XCTAssertTrue(setupSource.contains(".accessibilityElement(children: .contain)"))
125:         XCTAssertFalse(setupSource.contains("TextField"))
126:         XCTAssertFalse(setupSource.contains("validateAndSaveSessionKey"))
127:         XCTAssertFalse(setupSource.contains("validateAndSaveChatGPTSessionCookie"))
128: 
129:         XCTAssertTrue(settingsSource.contains("activeCredentialActionProvider"))
130:         XCTAssertTrue(settingsSource.contains("await performProviderCredentialAction(kind, for: status)"))
131:         XCTAssertTrue(settingsSource.contains("try await appModel.performProviderCredentialAction(kind, for: status.provider)"))
132:         XCTAssertTrue(settingsSource.contains("Reconnecting credentials from the signed-in browser session."))
133:         XCTAssertFalse(settingsSource.contains("case (.claude, .repair):"))
134:         XCTAssertFalse(settingsSource.contains("case (.chatGPT, .clear):"))
135:         XCTAssertFalse(settingsSource.contains("await repairClaudeSessionKey()"))
136:         XCTAssertFalse(settingsSource.contains("await clearSavedCredential(for: status.provider)"))
137:         XCTAssertFalse(settingsSource.contains("TextField"))
138:         XCTAssertFalse(settingsSource.contains("validateAndSaveSessionKey"))
139:         XCTAssertFalse(settingsSource.contains("validateAndSaveChatGPTSessionCookie"))
140:     }
