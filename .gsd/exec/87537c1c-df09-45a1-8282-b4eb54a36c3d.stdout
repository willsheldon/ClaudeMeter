94:     func test_settingsAndSetupRenderSharedProviderCredentialStatusModel() throws {
95:         let settingsSource = try sourceContents(relativePath: "Pinemeter/Views/Settings/SettingsView.swift")
96:         let setupSource = try sourceContents(relativePath: "Pinemeter/Views/Setup/SetupWizardView.swift")
97: 
98:         for source in [settingsSource, setupSource] {
99:             XCTAssertTrue(source.contains("providerCredentialStatuses"))
100:             XCTAssertTrue(source.contains("status.stateText"))
101:             XCTAssertTrue(source.contains("status.detailText"))
102:             XCTAssertTrue(source.contains("status.lastFailureTitle"))
103:             XCTAssertTrue(source.contains("handleCredentialAction(action.kind, for: status)"))
104:             XCTAssertFalse(source.contains("status.setupAccessibilityLabel"))
105:             XCTAssertFalse(source.contains("SecureField"))
106:             XCTAssertFalse(source.contains("sk-ant-"))
107:             XCTAssertFalse(source.contains("__Secure-next-auth.session-token"))
108:         }
109:     }
